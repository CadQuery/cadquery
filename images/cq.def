Bootstrap: docker
From: mambaorg/micromamba:latest

%files
    environment.yml /opt
    ./ /opt/cq

%post
    head -n -1 /opt/environment.yml  > /opt/environment_.yml
    micromamba install -y -q -n base -f /opt/environment_.yml
    micromamba run pip install -e /opt/cq
    micromamba list
    micromamba run pytest /opt/cq/tests
    micromamba clean --all --yes

%labels
    EnvironmentFile: environment.yml

%help
    This container container a Python environment with CadQuery.

    To run Python from the environment:

        apptainer run my_environment.sif ipython

    To see the environment file used to create the environment:

        apptainer run my_environment.sif cat /opt/environment.yml

    To see what packages are in the environment:

        apptainer run micromamba list
